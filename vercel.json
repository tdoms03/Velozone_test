{
    "builds": [
      {
        "src": "api/app.py",
        "use": "@vercel/python"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "api/app.py"
      }
    ],
    "functions": {
      "api/app.py": {
        "includeFiles": "api/**",
        "excludeFiles": "*.png *.xlsx *.md *.txt"
      }
    }
  }